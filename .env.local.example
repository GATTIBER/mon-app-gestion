# Secret used by NextAuth.js to sign session tokens.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# SQLite database file used by Prisma.
DATABASE_URL="file:./prisma/dev.db"

# Used only by `npm run db:seed` to create/update the demo admin user.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123!
