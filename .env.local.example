# Secret used by NextAuth.js to sign session tokens.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Demo admin account (temporary, until a real user store is added).
ADMIN_EMAIL=admin@example.com
# Generate a bcrypt hash with:
#   node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"
# IMPORTANT: escape every "$" as "\$", otherwise Next.js's env loader treats
# "$2b", "$10", etc. as variable references and silently truncates the hash.
ADMIN_PASSWORD_HASH=
